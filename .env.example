# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (required if output.email_enabled = true in settings.yaml) ──────────
EMAIL_USER=your.email@gmail.com
EMAIL_PASSWORD=your-app-password   # Gmail: use App Password, not account password

# ── Optional paid APIs ────────────────────────────────────────────────────────
# NEWS_API_KEY=your-newsapi-key          # newsapi.org for analyst news
# KITE_API_KEY=your-zerodha-kite-key    # Zerodha Kite for real-time NSE data
# KITE_API_SECRET=your-zerodha-secret
